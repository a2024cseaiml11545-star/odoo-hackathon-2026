<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_trip_tree" model="ir.ui.view">
        <field name="name">fleet.trip.tree</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="source"/>
                <field name="destination"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight"/>
                <field name="planned_distance"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="view_trip_form" model="ir.ui.view">
        <field name="name">fleet.trip.form</field>
        <field name="model">fleet.trip</field>
        <field name="arch" type="xml">
            <form>
            <header>
    <button name="action_dispatch"
            string="Dispatch"
            type="object"
            class="btn-primary"
            states="draft"/>

    <button name="action_complete"
            string="Complete"
            type="object"
            class="btn-success"
            states="dispatched"/>

    <button name="action_cancel"
            string="Cancel"
            type="object"
            class="btn-secondary"
            states="draft,dispatched"/>

    <field name="status" widget="statusbar"/>
</header>

                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="source"/>
                        <field name="destination"/>
                        <field name="vehicle_id"/>
                        <field name="driver_id"/>
                        <field name="cargo_weight"/>
                        <field name="planned_distance"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

</odoo>