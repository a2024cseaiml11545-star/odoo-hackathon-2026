<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_report_tree" model="ir.ui.view">
        <field name="name">fuel.expense.report.tree</field>
        <field name="model">fuel.expense.report</field>
        <field name="arch" type="xml">
            <tree>
                <field name="report_name"/>
                <field name="total_fuel_cost"/>
                <field name="total_expense"/>
                <field name="total_trips"/>
                <field name="generated_on"/>
            </tree>
        </field>
    </record>

    <record id="action_fuel_report" model="ir.actions.act_window">
        <field name="name">Reports</field>
        <field name="res_model">fuel.expense.report</field>
        <field name="view_mode">tree</field>
    </record>

</odoo>