<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_expense_tree" model="ir.ui.view">
        <field name="name">vehicle.expense.tree</field>
        <field name="model">vehicle.expense</field>
        <field name="arch" type="xml">
            <tree>
                <field name="expense_name"/>
                <field name="vehicle"/>
                <field name="expense_type"/>
                <field name="amount"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="action_vehicle_expense" model="ir.actions.act_window">
        <field name="name">Expenses</field>
        <field name="res_model">vehicle.expense</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>